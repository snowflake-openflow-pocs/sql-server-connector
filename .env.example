# SQL Server Configuration
SQL_HOST=localhost
SQL_PORT=1433
SQL_USER=sa
SQL_PASSWORD=<YOUR_SQL_PASSWORD>
SQL_DATABASE=DemoDB

# Data Generator Mode
DATA_MODE=steady  # steady|burst|mixed

# Snowflake Connection (for SPCS deployment)
SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com
SNOWFLAKE_USER=your-user
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_DATABASE=OPENFLOW_POCS
SNOWFLAKE_SCHEMA=SQL_SERVER_CDC
SNOWFLAKE_WAREHOUSE=CDC_DEMO_WH